rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global deny
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. Helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isSignedIn() && getUserData().role == role;
    }

    function isAdmin() {
      return hasRole('admin');
    }

    function isStaff() {
      return hasRole('staff') || isAdmin();
    }

    // 3. Entity Validations
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'role']) &&
             data.uid == request.auth.uid &&
             data.role in ['admin', 'staff', 'user'];
    }

    function isValidEvent(data) {
      return data.keys().hasAll(['title', 'date']) &&
             data.title is string && data.title.size() < 200;
    }

    function isValidNews(data) {
      return data.keys().hasAll(['title', 'content', 'date']) &&
             data.title is string && data.title.size() < 200;
    }

    function isValidGalleryItem(data) {
      return data.keys().hasAll(['imageUrl']) &&
             data.imageUrl is string;
    }

    function isValidStaff(data) {
      return data.keys().hasAll(['name', 'role']) &&
             data.name is string && data.role is string;
    }

    function isValidTestimonial(data) {
      return data.keys().hasAll(['userName', 'text']) &&
             data.userName is string && data.text is string;
    }

    function isValidDonation(data) {
      return data.keys().hasAll(['amount', 'date']) &&
             data.amount is number && data.amount > 0;
    }

    // 4. Collection Matches
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isSignedIn() && isValidUser(incoming());
      allow update: if isSignedIn() && (isAdmin() || (request.auth.uid == userId && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL'])));
    }

    match /events/{eventId} {
      allow read: if true;
      allow write: if isStaff() && isValidEvent(incoming());
    }

    match /news/{newsId} {
      allow read: if true;
      allow write: if isStaff() && isValidNews(incoming());
    }

    match /gallery/{itemId} {
      allow read: if true;
      allow write: if isStaff() && isValidGalleryItem(incoming());
    }

    match /staff/{staffId} {
      allow read: if true;
      allow write: if isAdmin() && isValidStaff(incoming());
    }

    match /testimonials/{testimonialId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidTestimonial(incoming());
      allow delete: if isAdmin();
    }

    match /donations/{donationId} {
      allow read: if isAdmin();
      allow create: if true; // Guest donations possible
    }
  }
}
